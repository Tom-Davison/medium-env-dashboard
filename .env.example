# Copy this file to .env and fill in your Sentinel Hub OAuth client.
#
# 1. Register (free) at https://dataspace.copernicus.eu
# 2. Open https://shapps.dataspace.copernicus.eu/dashboard/
#    -> User settings -> OAuth clients -> Create
# 3. Copy the id and secret here. The secret is shown only once.

SH_CLIENT_ID=your_client_id
SH_CLIENT_SECRET=your_client_secret
